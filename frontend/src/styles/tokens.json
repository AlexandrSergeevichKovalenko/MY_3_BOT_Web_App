{
  "theme": "Dark Minimal Premium Study Mode",
  "colors": {
    "bg": {
      "app": "#0F172A",
      "panel": "#111827",
      "card": "#1E293B",
      "cardAlt": "#0B1220",
      "hover": "#1F2937",
      "overlay": "rgba(15,23,42,0.85)"
    },
    "border": {
      "default": "#334155",
      "subtle": "#1F2937"
    },
    "text": {
      "primary": "#F8FAFC",
      "title": "#E2E8F0",
      "secondary": "#CBD5E1",
      "muted": "#94A3B8",
      "subtle": "#64748B"
    },
    "action": {
      "primary": "#2563EB",
      "success": "#16A34A",
      "danger": "#DC2626",
      "warning": "#EA580C",
      "onPrimary": "#FFFFFF",
      "onSuccess": "#FFFFFF",
      "onDanger": "#FFFFFF",
      "onWarning": "#FFFFFF"
    }
  },
  "shadows": {
    "card": "0 25px 50px rgba(0,0,0,0.45)",
    "cardStrong": "0 30px 60px rgba(0,0,0,0.50)",
    "buttonPrimary": "0 8px 20px rgba(37,99,235,0.35)"
  },
  "radius": {
    "screen": 28,
    "card": 28,
    "cardInner": 20,
