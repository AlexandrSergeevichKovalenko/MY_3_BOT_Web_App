  "spacing": [8, 12, 16, 20, 24, 32, 40, 48, 60, 80],
  "typography": {
    "fontFamily": ["SF Pro", "Inter", "system-ui"],
    "sizes": [12, 13, 14, 15, 16, 18, 20, 22, 26, 28, 30, 34],
    "weights": [500, 600, 700, 800],
    "lineHeights": {
      "hero": 1.1,
      "big": 1.25,
      "body": 1.4
    }
  },
  "components": {
    "buttonPrimary": { "height": 56, "radius": 16 },
    "buttonSecondary": { "height": 48, "radius": 14 },
    "chip": { "height": 40, "radius": 999 },
    "optionTile": { "height": 52, "radius": 14 },
    "modal": { "radius": 28 },
    "sidebar": { "activeAccentWidth": 3 }
  }
