AUDIO_DISPATCH_TOKEN=your_long_random_secret
BOT_ADMIN_TELEGRAM_IDS=123456789
TTS_PREWARM_ENABLED=1
TTS_PREWARM_INTERVAL_MINUTES=60
TTS_PREWARM_BATCH_SIZE=120
TTS_PREWARM_MAX_CHARS_PER_RUN=12000
TTS_PREWARM_LOOKBACK_HOURS=168
TTS_PREWARM_OFFPEAK_START_HOUR=1
TTS_PREWARM_OFFPEAK_END_HOUR=7
TTS_PREWARM_ALLOW_DAYTIME=0
LANGUAGE_PAIR_CACHE_TTL_SEC=900
FLASHCARD_FEEL_CLEANUP_ENABLED=1
FLASHCARD_FEEL_CLEANUP_DAY=1
FLASHCARD_FEEL_CLEANUP_HOUR=3
FLASHCARD_FEEL_CLEANUP_MINUTE=30

# LLM gateway rollout (Assistants -> Responses hybrid)
LLM_GATEWAY_MODE=hybrid
LLM_GATEWAY_MODEL=gpt-4.1-2025-04-14
LLM_RESPONSES_TASKS=dictionary_assistant_multilang,feel_word,feel_word_multilang,check_translation,check_translation_multilang,recheck_translation,generate_sentences,generate_sentences_multilang,generate_mystery_story,translate_subtitles_ru,translate_subtitles_multilang

# Billing / Economics
# Currency for billing ledgers and price snapshots.
BILLING_CURRENCY=USD

# Provider alert thresholds in % of monthly limit.
BILLING_PROVIDER_ALERT_THRESHOLDS=50,75,90

# Unit prices (USD)
GOOGLE_TTS_PRICE_PER_1M_CHARS_USD=16.0
GOOGLE_TRANSLATE_PRICE_PER_1M_CHARS_USD=20.0
DEEPL_PRICE_PER_1M_CHARS_USD=25.0
AZURE_TRANSLATOR_PRICE_PER_1M_CHARS_USD=10.0
PERPLEXITY_PRICE_PER_REQUEST_USD=0.005
CLOUDFLARE_R2_CLASS_A_PRICE_PER_1M_OPS_USD=4.5
CLOUDFLARE_R2_CLASS_B_PRICE_PER_1M_OPS_USD=0.36
CLOUDFLARE_R2_STORAGE_PRICE_PER_GB_MONTH_USD=0.015
STRIPE_API_REQUEST_PRICE_USD=0.0
STRIPE_PRICE_PER_PAYMENT_USD=0.0
YOUTUBE_API_PRICE_PER_1000_UNITS_USD=0.0

# Monthly base limits (for monitoring/alerts/blocking)
GOOGLE_TTS_MONTHLY_BASE_LIMIT_CHARS=1000000
GOOGLE_TRANSLATE_MONTHLY_BASE_LIMIT_CHARS=500000
DEEPL_MONTHLY_BASE_LIMIT_CHARS=500000
AZURE_TRANSLATOR_MONTHLY_BASE_LIMIT_CHARS=1000000
PERPLEXITY_MONTHLY_BASE_LIMIT_REQUESTS=20000
CLOUDFLARE_R2_CLASS_A_MONTHLY_BASE_LIMIT_OPS=1000000
CLOUDFLARE_R2_CLASS_B_MONTHLY_BASE_LIMIT_OPS=10000000
CLOUDFLARE_R2_STORAGE_MONTHLY_BASE_LIMIT_MB=10240
# Optional alternative to MB (if >0, overrides MB setting):
CLOUDFLARE_R2_STORAGE_MONTHLY_BASE_LIMIT_GB=0
STRIPE_MONTHLY_BASE_LIMIT_PAYMENTS=1000

# Optional Stripe fee formula for estimated processing fee event
STRIPE_FEE_PERCENT=2.9
STRIPE_FEE_FIXED_USD=0.30
